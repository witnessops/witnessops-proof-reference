{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://witnessops.internal/schemas/purple-detection/evidence-manifest.schema.json",
  "title": "Purple Detection Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proof_run_id",
    "parent_candidate",
    "classification",
    "target_boundary",
    "required_artifacts",
    "artifact_hashes",
    "stop_conditions_checked"
  ],
  "properties": {
    "proof_run_id": { "const": "PURPLE-DETECTION-FIXTURE-SPEC-V1" },
    "parent_candidate": { "const": "PRC-PURPLE-DETECTION" },
    "classification": { "const": "INTERNAL_ONLY" },
    "target_boundary": { "const": "synthetic_fixture_only" },
    "required_artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "contains": { "const": "ARTIFACTS/SCENARIO_DECLARATION.json" }
    },
    "artifact_hashes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "stop_conditions_checked": { "const": true }
  }
}
