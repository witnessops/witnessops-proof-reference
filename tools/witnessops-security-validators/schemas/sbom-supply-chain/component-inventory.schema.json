{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://witnessops.internal/schemas/sbom-supply-chain/component-inventory.schema.json",
  "title": "SBOM Supply Chain Component Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["inventory_id", "format", "components"],
  "properties": {
    "inventory_id": { "const": "sbom_fixture_inventory_v1" },
    "format": { "const": "internal_fixture" },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "type", "synthetic"],
        "properties": {
          "name": { "type": "string", "pattern": "^synthetic-[a-z0-9-]+$" },
          "version": { "type": "string", "minLength": 1 },
          "type": { "enum": ["library", "application", "container", "service"] },
          "synthetic": { "const": true }
        }
      }
    }
  }
}
