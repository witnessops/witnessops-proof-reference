{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://witnessops.internal/schemas/api-authz/fixture.schema.json",
  "title": "API Authorization Synthetic Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["fixture_id", "classification", "target_boundary", "actors", "objects"],
  "properties": {
    "fixture_id": { "const": "api_authz_fixture_v1" },
    "classification": { "const": "INTERNAL_ONLY" },
    "target_boundary": { "const": "synthetic_local_fixture_only" },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "synthetic"],
        "properties": {
          "id": { "type": "string", "pattern": "^actor_[a-z0-9_]+$" },
          "label": { "type": "string", "minLength": 1 },
          "synthetic": { "const": true }
        }
      }
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "owner_actor_id", "synthetic"],
        "properties": {
          "id": { "type": "string", "pattern": "^object_[a-z0-9_]+$" },
          "owner_actor_id": { "type": "string", "pattern": "^actor_[a-z0-9_]+$" },
          "synthetic": { "const": true }
        }
      }
    }
  }
}
