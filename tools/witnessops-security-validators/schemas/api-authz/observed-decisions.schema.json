{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://witnessops.internal/schemas/api-authz/observed-decisions.schema.json",
  "title": "API Authorization Observed Decisions",
  "type": "object",
  "additionalProperties": false,
  "required": ["observed_decisions"],
  "properties": {
    "observed_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["request_id", "actor_id", "object_id", "action", "expected_decision", "observed_decision"],
        "properties": {
          "request_id": { "type": "string", "pattern": "^req_[0-9]+$" },
          "actor_id": { "type": "string", "pattern": "^actor_[a-z0-9_]+$" },
          "object_id": { "type": "string", "pattern": "^object_[a-z0-9_]+$" },
          "action": { "enum": ["read", "write", "delete"] },
          "expected_decision": { "enum": ["allow", "deny"] },
          "observed_decision": { "enum": ["allow", "deny"] }
        }
      }
    }
  }
}
